{
	"name": "sv-monorepo",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"description": "monorepo for sv and friends",
	"engines": {
		"pnpm": "^10.0.0"
	},
	"scripts": {
		"build": "tsdown",
		"postbuild": "node scripts/generate-api-surface.js",
		"changeset:publish": "changeset publish",
		"check": "pnpm --parallel check",
		"dev": "tsdown -w & pnpm --parallel check -w & wait",
		"format": "pnpm --parallel format",
		"lint": "pnpm --parallel lint && eslint --cache --cache-location node_modules/.eslintcache",
		"test": "vitest run --silent",
		"test:ecosystem-ci": "vitest run --exclude='**/storybook/test.ts'",
		"test:ui": "vitest --ui",
		"update-deps": "node ./scripts/update-dependencies.js && pnpm format"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/eslint-config": "^10.0.1",
		"@svitejs/changesets-changelog-github-compact": "^1.2.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260601.1",
		"@vitest/ui": "4.1.8",
		"eslint": "^10.4.1",
		"eslint-plugin-svelte": "^3.19.0",
		"magic-string": "^0.30.21",
		"prettier": "^3.8.3",
		"prettier-plugin-packagejson": "^3.0.2",
		"prettier-plugin-svelte": "^4.1.0",
		"sv": "workspace:*",
		"svelte": "^5.56.1",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vitest": "4.1.8"
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
